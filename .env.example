# ============================================================================
# LiMem 长时记忆系统配置文件
# ============================================================================
# 说明：复制此文件为 .env 并根据需要修改参数值
# 用法：保存记忆时使用（LTM） | 搜索时使用（SEARCH）
# ============================================================================

# ----------------------------------------------------------------------------
# API 配置 [通用]
# ----------------------------------------------------------------------------
# DashScope API Key (阿里云)
DASHSCOPE_API_KEY=your-api-key-here

# DashScope API Base URL
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# LLM 生成模型 (用于实体抽取、答案生成等)
# 选项: qwen3-1.7b, qwen-plus, qwen-turbo 等
GENERATION_MODEL=qwen3-1.7b

# 向量嵌入模型 (用于实体、事件的向量化)
# 选项: text-embedding-v2, text-embedding-v3 等
EMBEDDING_MODEL=text-embedding-v2

# 是否启用 LLM Thinking 模式 (扩展推理)
# 选项: true/false
ENABLE_THINKING=false


# ============================================================================
# 保存记忆时使用的参数 (LTM - ResearchLTM)
# ============================================================================

# ----------------------------------------------------------------------------
# 事件合并与记忆巩固参数 [保存记忆时使用]
# ----------------------------------------------------------------------------
# 事件相似度阈值：用于判断新事件是否与已有事件相似（多维度综合得分）
# 用途：当新事件与已有事件的综合相似度 >= 此值时，会合并到已有事件
# 范围：0.0-1.0，推荐值 0.60-0.75（多维度评分通常比纯向量相似度低）
# 影响：
#   - 过高：会产生更多细粒度的事件，可能造成记忆碎片化
#   - 过低：可能将不同的事件错误合并，丢失细节
# 注意：这是多维度评分（语义+实体+时间+动作），不是纯向量相似度
SIMILARITY_THRESHOLD=0.65

# 多维度合并权重（四者之和应为 1.0）
# 用途：控制不同维度对事件合并决策的贡献度
# MERGE_WEIGHT_SEMANTIC: 向量语义相似度权重（文本嵌入的余弦相似度）
# MERGE_WEIGHT_ENTITY: 实体重叠度权重（Jaccard相似度，基于共同实体）
# MERGE_WEIGHT_TIME: 时间接近度权重（指数衰减，越近的事件得分越高）
# MERGE_WEIGHT_ACTION: 动作类型匹配权重（完全匹配得1分，否则0分）
# 推荐配置：
#   - 语义驱动：SEMANTIC=0.5, ENTITY=0.3, TIME=0.1, ACTION=0.1
#   - 实体驱动：SEMANTIC=0.3, ENTITY=0.5, TIME=0.1, ACTION=0.1
#   - 时间敏感：SEMANTIC=0.3, ENTITY=0.2, TIME=0.4, ACTION=0.1
MERGE_WEIGHT_SEMANTIC=0.4
MERGE_WEIGHT_ENTITY=0.3
MERGE_WEIGHT_TIME=0.2
MERGE_WEIGHT_ACTION=0.1

# 时间窗口：用于判断事件是否在"同一时间段"（秒）
# 用途：时间窗口内的事件会获得更高的时间相似度得分
# 范围：正整数，推荐值 300-900（5-15分钟）
# 影响：
#   - 过小：时间稍有差异就大幅降低相似度
#   - 过大：不同时间的事件可能被错误判定为"同时"
MERGE_TIME_WINDOW=300

# Episode（原始对话）生存时间 (秒)
# 用途：Episodes 是原始对话记录，提取事件后可根据此参数自动清理
# 范围：正整数，推荐值 3600 (1小时)
# 影响：设置过小可能丢失原始数据，过大占用存储空间
EPISODE_TTL=3600


# ----------------------------------------------------------------------------
# 权重衰减率参数 [保存记忆时使用]
# ----------------------------------------------------------------------------
# 默认衰减率 (FIXED: 调整为适合秒级时间戳的值)
# 用途：控制记忆权重随时间的衰减速度
# 公式：weight = log(1 + c_valid) * exp(-DECAY_RATE * time_diff)
# 范围：浮点数，推荐值 1e-8 (半衰期约2.2年)
# 影响：
#   - 过高：旧记忆快速衰减，系统更关注近期事件
#   - 过低：旧记忆保持更久，系统具有长期记忆特性
# 计算公式：half_life = ln(2) / DECAY_RATE
#   - 1e-8: 半衰期 ≈ 2.2年 (适合长期记忆，推荐)
#   - 1e-7: 半衰期 ≈ 81天 (适合中短期记忆)
#   - 1e-6: 半衰期 ≈ 8天 (适合短期记忆)
#   - 1e-5: 半衰期 ≈ 0.8天 (适合超短期记忆)
DECAY_RATE=1e-8

# P2 优先级衰减率 (半永久性偏好，如用户喜好)
# 通常设为较低值，使这类记忆衰减更慢
# 推荐值：与 DECAY_RATE 相同或略小
DECAY_RATE_P2=0.01

# P3 优先级衰减率 (临时性事件，如单次操作)
# 通常设为较高值，使这类记忆快速衰减
# 推荐值：DECAY_RATE * 2
DECAY_RATE_P3=0.02


# ----------------------------------------------------------------------------
# 记忆修剪参数 [保存记忆时使用]
# ----------------------------------------------------------------------------
# c_valid 阈值：当事件-关系的确认次数超过此值时，触发记忆巩固
# 用途：将高频记忆标记为用户的永久特征
# 范围：正整数，推荐值 50-200
# 影响：达到此阈值的事件会被提升为"永久特征"
PRUNE_C_VALID_THRESHOLD=100

# 保留的证据数量 Top-K
# 用途：限制每个事件保留的证据条数，避免无限增长
# 范围：正整数，推荐值 3-10
# 影响：只保留置信度最高的 K 条证据
PRUNE_EVIDENCE_TOP_K=5


# ----------------------------------------------------------------------------
# 默认用户配置 [保存记忆时使用]
# ----------------------------------------------------------------------------
# 默认用户 ID
# 用途：当未指定用户时使用的默认标识
DEFAULT_USER_ID=default_user


# ============================================================================
# 搜索时使用的参数 (SEARCH - LTMSearcher)
# ============================================================================

# ----------------------------------------------------------------------------
# 搜索结果数量控制 [搜索时使用]
# ----------------------------------------------------------------------------
# 返回的 Top-K 事件数量
# 用途：控制每次搜索返回的最相关事件数量
# 范围：正整数，推荐值 3-10
# 影响：影响最终答案的质量和生成速度
SEARCH_TOP_K=5


# ----------------------------------------------------------------------------
# 搜索权重计算参数 [搜索时使用]
# ----------------------------------------------------------------------------
# 搜索权重衰减率 (lambda 参数)
# 用途：计算事件权重时的衰减系数，与保存记忆时的衰减率独立
# 公式：weight = log(1 + c_valid) * exp(-lambda * time_diff)
# 范围：浮点数，推荐值 1e-9 到 0.01
# 注意：应设为很小的值，否则历史事件的权重会衰减为 0
SEARCH_LAMBDA=1e-9


# ----------------------------------------------------------------------------
# 实体抽取参数 [搜索时使用]
# ----------------------------------------------------------------------------
# 从查询中提取的最大实体数量
# 用途：限制 LLM 从用户查询中提取的实体数量
# 范围：正整数，推荐值 10-50
# 影响：
#   - 过小：可能遗漏关键实体
#   - 过大：可能引入噪音，降低检索精度
SEARCH_MAX_ENTITIES=10


# ----------------------------------------------------------------------------
# 答案生成参数 [搜索时使用]
# ----------------------------------------------------------------------------
# LLM 生成答案的最大 token 数
# 用途：控制生成的回答长度
# 范围：正整数，推荐值 256-1024
# 影响：值越大回答越详细，但生成速度越慢
SEARCH_MAX_TOKENS=512

# LLM 生成答案的温度参数
# 用途：控制生成的随机性和创造性
# 范围：0.0-1.0
#   - 0.0-0.3：更确定性、事实性的回答
#   - 0.4-0.7：平衡的创造性
#   - 0.8-1.0：更随机、更有创造性
SEARCH_TEMPERATURE=0.7


# ----------------------------------------------------------------------------
# 向量匹配参数 [搜索时使用]
# ----------------------------------------------------------------------------
# 是否启用向量语义匹配
# 用途：在字符精确匹配之外，启用基于向量的语义匹配
# 选项：true/false
# 效果：启用后可匹配语义相似的实体（如"医院"→"北京协和医院"）
SEARCH_ENABLE_VECTOR_MATCH=true

# 向量相似度阈值
# 用途：只有相似度 >= 此值的实体才会被匹配
# 范围：0.0-1.0，推荐值 0.5-0.8
# 影响：
#   - 过高：匹配更精确，但可能漏掉语义相关但表达不同的实体
#   - 过低：召回率高，但可能引入不相关的实体
SEARCH_VECTOR_THRESHOLD=0.5

# 向量匹配 Top-K 数量
# 用途：对每个查询实体，最多匹配 K 个最相似的数据库实体
# 范围：正整数，推荐值 5-20
# 影响：控制向量匹配的召回范围
SEARCH_VECTOR_TOP_K=10


# ============================================================================
# 数据加载配置 [数据加载时使用]
# ============================================================================
# 测试数据文件路径
TEST_DATA_PATH=./example.json

# 测试数据集 Key (指定加载哪个数据集)
# 选项：具体的数据集 key 或 "ALL" 加载所有
TEST_DATASET_KEY=ALL

# 最大加载 Episode 数量
# 用途：限制从测试数据中加载的对话数量
# 范围：正整数
MAX_EPISODES=500


# ============================================================================
# 数据库配置 [通用]
# ============================================================================
# Kuzu 数据库文件路径
DB_PATH=./DB/demo_db.kz


# ============================================================================
# 图可视化配置 [可视化时使用]
# ============================================================================
# 是否导出完整图
EXPORT_FULL_GRAPH=true

# 是否在图中包含 Episode 节点
INCLUDE_EPISODES_IN_GRAPH=false

# 导出图的最大事件数量 (0 表示无限制)
GRAPH_MAX_EVENTS=100


# ============================================================================
# Kuzu Explorer 配置 [可视化时使用]
# ============================================================================
# Kuzu Explorer 访问 URL
KUZU_EXPLORER_URL=http://localhost:8000/

# 数据库文件名
KUZU_FILE=demo_db.kz


# ============================================================================
# 主动建议引擎配置 [主动建议功能使用]
# ============================================================================
# 触发建议的权重阈值
# 用途：当事件权重 >= 此值时，系统会主动生成建议
# 范围：浮点数，推荐值 0.1-0.5
PROACTIVE_WEIGHT_THRESHOLD=0.2

# 主动建议的最小时间间隔 (秒)
# 用途：避免频繁打扰用户，两次建议之间的最小间隔
# 范围：正整数，推荐值 1800 (30分钟)
PROACTIVE_TIME_GAP_SEC=1800


# ============================================================================
# 图导出配置 [可视化时使用]
# ============================================================================
# 图导出目录
GRAPH_OUTPUT_DIR=./outputs

# 是否导出图
EXPORT_GRAPH=true

# 每个 Episode 后是否导出图
EXPORT_EVERY_EPISODE=true
